# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
e2e/fixtures/db-dump.sql

# coverage - e2e (full reports gitignored, summary committed)
/coverage/*
!/coverage/coverage-summary.json
/.v8-coverage/
/monocart-report/
/assets/

# coverage - unit tests (generated locally and in CI, never committed)
/unit-coverage/

# fallow
/.fallow/
/.var/fallow/

# next.js
/.next/
/.next-test/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example
!.env.staging.example
!.env.production.example
!.env.test.example

# typescript
*.tsbuildinfo
next-env.d.ts

# temp scripts
/temp_scripts/
.env*.local

.planning
ralph/*
.ralph/
pral/
.claude/
CLAUDE.local.md
graphify-out/
.env.dont.touch
# Discord bot scripts
start-discord-bot.sh
stop-discord-bot.sh

# Local uploaded centre export data
.discord-attachments/
centres-for-crud-ui/
centre_name_table.csv
centre_name_mapping_template.csv

# Roster data (PII) — regenerated locally from the sheet/DB, never committed
scripts/data/pm/
